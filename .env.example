# Copy this file to .env and fill in real values. Never commit .env itself.
# All variables are read with the APP_ prefix (see app/core/config.py).

# development | staging | production
APP_ENVIRONMENT=development

# DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# Optional overrides — defaults resolve to the repo's scenarios/ and prompts/ folders.
# APP_SCENARIOS_DIR=scenarios
# APP_PROMPTS_DIR=prompts

# No third-party API keys are used yet in Phase 1 (mock providers only).
# Real provider credentials (LLM, transcription, speech) will be added here
# in a later phase.
